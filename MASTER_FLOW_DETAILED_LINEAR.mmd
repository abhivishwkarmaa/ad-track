flowchart LR
    %% ---------------- Tracking ----------------
    subgraph T[Tracking Flow]
        direction LR
        A[Publisher Traffic] --> B[/click endpoint/]
        B --> C[Tenant + Offer + Publisher Validation]
        C --> D[Redis Click Hash + stream:clicks]
        D --> E[Click Worker]
        E --> F[(clicks table)]
    end

    %% ---------------- Attribution ----------------
    subgraph A2[Attribution Flow]
        direction LR
        G[Merchant Postback] --> H[/postback endpoint/]
        H --> I[Redis-first Context Resolution]
        I --> J[Deterministic Status + Capping]
        J --> K[Redis conversion payload + stream:conversions]
        K --> L[Conversion Worker]
        L --> M[(conversions table)]
        L --> N[(daily_offer_stats / daily_click_stats)]
        L --> O[Affiliate Callback if approved]
    end

    %% ---------------- Reporting ----------------
    subgraph R2[Reporting Flow]
        direction LR
        P[React Dashboard] --> Q[/api/admin/reports/*/]
        Q --> F
        Q --> M
        Q --> N
        Q --> R[Charts / KPI / Live Logs UI]
    end

