# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Database (MySQL — adjust to match your deployment)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pulpy_reporting
DB_USER=root
DB_PASSWORD=

# JWT — development may use any non-empty strings; do NOT use placeholder values in production.
# In production (NODE_ENV=production), the process exits on startup if secrets are missing or equal to built-in placeholders.
# ADMIN_JWT_SECRET — signing/verification for super-admin tokens
# TENANT_JWT_SECRET — signing/verification for tenant-admin tokens
# JWT_SECRET — optional shared fallback; also used for legacy token verification path
ADMIN_JWT_SECRET=
TENANT_JWT_SECRET=
JWT_SECRET=

JWT_EXPIRES_IN=7d

# CORS — required in production: comma-separated browser origins (e.g. https://admin.example.com,https://app.example.com)
# Non-production: defaults include http://localhost:5173 and http://127.0.0.1:5173; optional extra origins via this list
CORS_ORIGINS=

# Tracking debug HTTP routes (/debug/clicks, /debug/validate/*, /debug/worker-status)
# In production, defaults off; set to true or 1 to enable
ENABLE_TRACKING_DEBUG_ROUTES=false

# Test-only API mounted at /api/test-postback — off in production unless explicitly enabled
ENABLE_TEST_POSTBACK_ROUTES=false

# Application URLs
BASE_URL=http://localhost:5000
TRACKING_DOMAIN=http://localhost:5000

# Logging
LOG_LEVEL=info
